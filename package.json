{
  "name": "discord-telegram-forwarder",
  "version": "1.0.0",
  "description": "Discord to Telegram message forwarder bot",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "start:live": "node scripts/run-bot.js",
    "start:log": "node scripts/run-bot.js --log",
    "test:telegram": "node scripts/test-telegram.js",
    "pm2:start": "set PM2_HOME=.pm2&& pm2 start ecosystem.config.cjs",
    "pm2:restart": "set PM2_HOME=.pm2&& pm2 restart discord-telegram-forwarder",
    "pm2:stop": "set PM2_HOME=.pm2&& pm2 stop discord-telegram-forwarder",
    "pm2:logs": "set PM2_HOME=.pm2&& pm2 logs discord-telegram-forwarder"
  },
  "keywords": ["discord", "telegram", "bot", "forwarder"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.14.0",
    "node-telegram-bot-api": "^0.63.0",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "pm2": "^5.4.3"
  }
}
