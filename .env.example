# Required
DISCORD_BOT_TOKEN=your_discord_bot_token_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional
# Comma-separated list of Discord channel IDs to forward from.
DISCORD_ALLOWED_CHANNEL_IDS=

# Set to true only while debugging Telegram updates.
DEBUG_TELEGRAM_UPDATES=false

# Optional Redis connection string for persistent channel routing and bot state.
# Example:
# REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://username:password@host:6379
REDIS_URL=
